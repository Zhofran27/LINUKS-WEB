{
  "experimentalServices": {
    "frontend": {
      "root": "Frontend",
      "framework": "nextjs",
      "buildCommand": "npm run build",
      "installCommand": "npm install",
      "routePrefix": "/"
    },
    "backend": {
      "root": "Backend",
      "framework": "express",
      "buildCommand": "npm run build",
      "installCommand": "npm install --legacy-peer-deps",
      "routePrefix": "/api"
    }
  }
}