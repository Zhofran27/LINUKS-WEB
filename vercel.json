{
  "experimentalServices": {
    "frontend": {
      "root": "frontend",
      "framework": "nextjs",
      "buildCommand": "npm run build",
      "installCommand": "npm install --include=dev",
      "routePrefix": "/"
    },
    "backend": {
      "root": "backend",
      "framework": "express",
      "buildCommand": "npm run build",
      "installCommand": "npm install --legacy-peer-deps",
      "routePrefix": "/api"
    }
  }
}